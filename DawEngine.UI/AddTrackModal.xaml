<Window x:Class="DawEngine.UI.AddTrackModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar pista" Height="340" Width="480"
        Background="#0A0A0A" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" FontFamily="Segoe UI"
        WindowStyle="None" AllowsTransparency="True">

    <Border Background="#0F0F0F" CornerRadius="10" MouseLeftButtonDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="NUEVA PISTA" Foreground="White" FontSize="14" FontWeight="Bold"/>
                <Button HorizontalAlignment="Right" Click="BtnCancel_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="X" Text="✕" Foreground="#444" FontSize="14"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="X" Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Opciones de tipo -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Audio -->
                <Border Grid.Column="0" Grid.Row="0" Name="CardAudio"
                        Background="#111" CornerRadius="8" Margin="0,0,6,6"
                        BorderBrush="#222" BorderThickness="1" Cursor="Hand"
                        MouseLeftButtonDown="Card_Click">
                    <Border.Tag>Audio</Border.Tag>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="🎵" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Audio" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Importar WAV / MP3 / FLAC" Foreground="#555"
                                   FontSize="9" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Grabación en vivo -->
                <Border Grid.Column="1" Grid.Row="0" Name="CardLive"
                        Background="#1A0A0A" CornerRadius="8" Margin="6,0,0,6"
                        BorderBrush="#2A1010" BorderThickness="1" Cursor="Hand"
                        MouseLeftButtonDown="Card_Click">
                    <Border.Tag>Live</Border.Tag>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="🎸" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Grabación en vivo" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Guitarra / Mic / ASIO" Foreground="#554040"
                                   FontSize="9" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- MIDI -->
                <Border Grid.Column="0" Grid.Row="1" Name="CardMidi"
                        Background="#0F0A1A" CornerRadius="8" Margin="0,0,6,0"
                        BorderBrush="#1A1025" BorderThickness="1" Cursor="Hand"
                        MouseLeftButtonDown="Card_Click">
                    <Border.Tag>MIDI</Border.Tag>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="🎹" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="MIDI / Instrumento" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Instrumento virtual" Foreground="#403055"
                                   FontSize="9" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Bus -->
                <Border Grid.Column="1" Grid.Row="1" Name="CardBus"
                        Background="#0A1008" CornerRadius="8" Margin="6,0,0,0"
                        BorderBrush="#1A2A15" BorderThickness="1" Cursor="Hand"
                        MouseLeftButtonDown="Card_Click">
                    <Border.Tag>Bus</Border.Tag>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="🔀" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bus / Grupo" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Enrutar varias pistas" Foreground="#304020"
                                   FontSize="9" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="2" Text="Haz clic en el tipo de pista para agregar"
                       Foreground="#333" FontSize="9" HorizontalAlignment="Center"
                       Margin="0,16,0,0" FontFamily="Courier New"/>
        </Grid>
    </Border>
</Window>
