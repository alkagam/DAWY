<Window x:Class="DawEngine.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DAWY" Height="540" Width="420"
        Background="#0A0A0A" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        FontFamily="Segoe UI">

    <Border Background="#0A0A0A" CornerRadius="14" MouseLeftButtonDown="Border_MouseDown">
        <Grid Margin="36,32,36,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <TextBlock Text="DAWY" Foreground="White" FontSize="30" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Border Background="#FF007F" CornerRadius="3" Padding="7,2" Margin="0,0,6,0">
                        <TextBlock Text="DAW" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#141414" CornerRadius="3" Padding="7,2">
                        <TextBlock Text="PRO  //  ESIME" Foreground="#444" FontSize="9" FontFamily="Courier New"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Formulario -->
            <StackPanel Grid.Row="1">

                <!-- Tab selector: Login / Registro -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Name="TabLogin" Grid.Column="0" Content="Iniciar sesión"
                            Click="TabLogin_Click" Padding="0,8"
                            Background="Transparent" BorderThickness="0,0,0,2"
                            BorderBrush="#FF007F" Foreground="White" FontSize="13" Cursor="Hand"/>
                    <Button Name="TabRegister" Grid.Column="1" Content="Crear cuenta"
                            Click="TabRegister_Click" Padding="0,8"
                            Background="Transparent" BorderThickness="0,0,0,1"
                            BorderBrush="#222" Foreground="#444" FontSize="13" Cursor="Hand"/>
                </Grid>

                <!-- Panel Login -->
                <StackPanel Name="PanelLogin">
                    <TextBlock Text="Correo electrónico" Foreground="#555" FontSize="11" Margin="0,0,0,6"/>
                    <Border Background="#111" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                        <TextBox Name="TxtEmail" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="13"
                                 CaretBrush="#FF007F"/>
                    </Border>

                    <TextBlock Text="Contraseña" Foreground="#555" FontSize="11" Margin="0,0,0,6"/>
                    <Border Background="#111" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20">
                        <PasswordBox Name="TxtPassword" Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="12,10" FontSize="13"
                                     CaretBrush="#FF007F"/>
                    </Border>

                    <Button Name="BtnLogin" Content="Entrar a DAWY"
                            Click="BtnLogin_Click" Height="44"
                            Background="#FF007F" Foreground="White"
                            BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border Height="1" Background="#141414" Margin="0,18,0,18"/>

                    <Button Name="BtnGuest" Content="Continuar como invitado"
                            Click="BtnGuest_Click" Height="40"
                            Background="#111" Foreground="#666"
                            BorderBrush="#1E1E1E" BorderThickness="1" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Panel Registro -->
                <StackPanel Name="PanelRegister" Visibility="Collapsed">
                    <TextBlock Text="Nombre" Foreground="#555" FontSize="11" Margin="0,0,0,6"/>
                    <Border Background="#111" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                        <TextBox Name="TxtName" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="13" CaretBrush="#FF007F"/>
                    </Border>

                    <TextBlock Text="Correo electrónico" Foreground="#555" FontSize="11" Margin="0,0,0,6"/>
                    <Border Background="#111" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                        <TextBox Name="TxtEmailReg" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="13" CaretBrush="#FF007F"/>
                    </Border>

                    <TextBlock Text="Contraseña" Foreground="#555" FontSize="11" Margin="0,0,0,6"/>
                    <Border Background="#111" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20">
                        <PasswordBox Name="TxtPasswordReg" Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="12,10" FontSize="13" CaretBrush="#FF007F"/>
                    </Border>

                    <Button Name="BtnRegister" Content="Crear cuenta"
                            Click="BtnRegister_Click" Height="44"
                            Background="#FF007F" Foreground="White"
                            BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Footer -->
            <TextBlock Grid.Row="2" Text="DAWY  v1.0  //  ESIME  IPN"
                       Foreground="#222" FontSize="9" FontFamily="Courier New"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>

            <!-- Botón cerrar -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Click="BtnClose_Click" Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Margin="0,-8,-8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="X" Text="✕" Foreground="#333" FontSize="16"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="X" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
