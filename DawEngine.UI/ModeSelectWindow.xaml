<Window x:Class="DawEngine.UI.ModeSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DAWY — Seleccionar modo" Height="580" Width="620"
        Background="#0A0A0A" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="InstChip" TargetType="Border">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="#0A0A0A" CornerRadius="14" MouseLeftButtonDown="Border_MouseDown">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Name="TxtUserGreet" Text="Bienvenido"
                               Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="// SELECCIONA EL MODO DE TRABAJO"
                               Foreground="#333" FontSize="10" FontFamily="Courier New" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnBack_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="X" Text="✕" Foreground="#333" FontSize="16"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="X" Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Contenido paginado -->
            <Grid Grid.Row="1">

                <!-- PÁGINA 1: Selección de modo -->
                <Grid Name="PageMode">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Modo En Vivo -->
                    <Border Name="CardLive" Grid.Column="0" Margin="0,0,8,0"
                            Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="12" Cursor="Hand" MouseLeftButtonDown="CardLive_Click">
                        <StackPanel Margin="20,22,20,22">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Background="#1A0808" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Modo En Vivo" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12" LineHeight="18" Margin="0,0,0,14">
                                Toca en tiempo real con latencia cero. Driver ASIO exclusivo para tu interfaz de audio.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Background="#1A0808" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="ASIO" Foreground="#FF4444" FontSize="10" FontFamily="Courier New"/>
                                </Border>
                                <Border Background="#1A0808" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="Baja latencia" Foreground="#FF4444" FontSize="10" FontFamily="Courier New"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#141414" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="Rack 19 efectos" Foreground="#555" FontSize="10" FontFamily="Courier New"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Modo Estudio -->
                    <Border Name="CardStudio" Grid.Column="1" Margin="8,0,0,0"
                            Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="12" Cursor="Hand" MouseLeftButtonDown="CardStudio_Click">
                        <StackPanel Margin="20,22,20,22">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Background="#081218" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="🎛" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Modo Estudio" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12" LineHeight="18" Margin="0,0,0,14">
                                Mezcla y edita pistas grabadas. WASAPI compartido — Spotify y YouTube funcionan en paralelo.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Background="#081218" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="WASAPI" Foreground="#00E5FF" FontSize="10" FontFamily="Courier New"/>
                                </Border>
                                <Border Background="#081218" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="Multipista" Foreground="#00E5FF" FontSize="10" FontFamily="Courier New"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#141414" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="Draw.ia" Foreground="#555" FontSize="10" FontFamily="Courier New"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- PÁGINA 2: Selección de instrumento (Modo En Vivo) -->
                <Grid Name="PageInstrument" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="// SELECCIONA TU INSTRUMENTO"
                               Foreground="#333" FontSize="10" FontFamily="Courier New" Margin="0,0,0,16"/>

                    <UniformGrid Grid.Row="1" Columns="3" Rows="2">
                        <Border Name="ChipGuitar"  Style="{StaticResource InstChip}" MouseLeftButtonDown="Chip_Click" Tag="Guitarra eléctrica">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🎸" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Name="LblGuitar" Text="Guitarra" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Name="ChipBass"    Style="{StaticResource InstChip}" MouseLeftButtonDown="Chip_Click" Tag="Bajo eléctrico" Margin="8,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🎵" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Name="LblBass" Text="Bajo" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Name="ChipVoice"   Style="{StaticResource InstChip}" MouseLeftButtonDown="Chip_Click" Tag="Voz / Micrófono">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🎙" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Name="LblVoice" Text="Voz / Mic" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Name="ChipKeys"    Style="{StaticResource InstChip}" MouseLeftButtonDown="Chip_Click" Tag="Teclado / Synth" Margin="0,8,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🎹" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Name="LblKeys" Text="Teclado" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Name="ChipDrums"   Style="{StaticResource InstChip}" MouseLeftButtonDown="Chip_Click" Tag="Batería electrónica" Margin="8,8,8,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🥁" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Name="LblDrums" Text="Batería" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0A0A0A" BorderBrush="#111" BorderThickness="1" CornerRadius="10" Margin="0,8,0,0">
                            <TextBlock Text="+" Foreground="#222" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </UniformGrid>

                    <Button Grid.Row="2" Name="BtnEnterLive"
                            Content="Entrar al DAW en vivo →"
                            Click="BtnEnterLive_Click"
                            Height="44" Margin="0,16,0,0"
                            Background="#FF007F" Foreground="White"
                            BorderThickness="0" FontSize="14" FontWeight="Bold"
                            Cursor="Hand" IsEnabled="False" Opacity="0.3">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Opacity="{TemplateBinding Opacity}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </Grid>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                <Button Name="BtnBackMode" Content="← Volver" Visibility="Collapsed"
                        Click="BtnBackMode_Click" Background="Transparent"
                        BorderThickness="0" Foreground="#444" FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
