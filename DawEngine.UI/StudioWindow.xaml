<Window x:Class="DawEngine.UI.StudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DAWY — Modo Estudio" Height="860" Width="1400"
        Background="#0A0A0A" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="TransBtn" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E1E1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header / Transporte -->
            <RowDefinition Height="*"/>    <!-- Zona principal -->
            <RowDefinition Height="180"/>  <!-- Effects Rack -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#141414" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + modo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="DAWY" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                    <Border Background="#081218" CornerRadius="4" Padding="7,3">
                        <TextBlock Text="ESTUDIO" Foreground="#00E5FF" FontSize="9" FontFamily="Courier New" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <!-- Transporte centrado -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" >
                    <Button Style="{StaticResource TransBtn}" Content="⏮" Margin="0,0,6,0" Click="BtnRewind_Click"/>
                    <Button Name="BtnPlay" Style="{StaticResource TransBtn}" Margin="0,0,6,0" Click="BtnPlay_Click">
                        <TextBlock Text="▶" Foreground="#00E5FF"/>
                    </Button>
                    <Button Name="BtnPause" Style="{StaticResource TransBtn}" Margin="0,0,6,0"
                            Click="BtnPause_Click" IsEnabled="False">
                        <TextBlock Text="⏸" Foreground="#666"/>
                    </Button>
                    <Button Name="BtnStop" Style="{StaticResource TransBtn}" Margin="0,0,16,0"
                            Click="BtnStop_Click" IsEnabled="False">
                        <TextBlock Text="⏹" Foreground="#FF3333"/>
                    </Button>

                    <!-- Posición / tiempo -->
                    <Border Background="#111" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Name="TxtPosition" Text="00:00.00" Foreground="#00E5FF"
                                       FontSize="14" FontFamily="Courier New" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Name="TxtRemaining" Text="-00:00" Foreground="#334"
                                           FontSize="9" FontFamily="Courier New" Margin="0,0,6,0"/>
                                <TextBlock Name="TxtBarBeat" Text="1:1" Foreground="#336"
                                           FontSize="9" FontFamily="Courier New"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Barra de progreso de la canción -->
                    <Border Width="120" Height="6" Background="#111" CornerRadius="3"
                            VerticalAlignment="Center" Margin="0,0,12,0"
                            Cursor="Hand" MouseLeftButtonDown="ProgressBar_Click">
                        <Border Name="ProgressFill" HorizontalAlignment="Left" Width="0"
                                Background="#00E5FF" CornerRadius="3"/>
                    </Border>

                    <!-- BPM -->
                    <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="BPM" Foreground="#333" FontSize="8" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Border Background="#111" CornerRadius="5" Padding="8,4" Margin="0,0,3,0">
                                <TextBlock Name="TxtBpm" Text="120" Foreground="#FF007F"
                                           FontSize="14" FontFamily="Courier New" FontWeight="Bold"
                                           MinWidth="32" TextAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <Button Height="13" Width="16" Content="▲" FontSize="7"
                                        Background="#141414" Foreground="#555" BorderThickness="0"
                                        Cursor="Hand" Click="BtnBpmUp_Click" Padding="0"/>
                                <Button Height="13" Width="16" Content="▼" FontSize="7"
                                        Background="#141414" Foreground="#555" BorderThickness="0"
                                        Cursor="Hand" Click="BtnBpmDown_Click" Padding="0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Tap Tempo -->
                    <Button Content="TAP" Click="BtnTap_Click" Height="30" Padding="8,0"
                            Background="#141414" Foreground="#555" BorderBrush="#222"
                            BorderThickness="1" FontSize="10" FontFamily="Courier New"
                            Cursor="Hand" Margin="0,0,16,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Controles derecha -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">

                    <!-- VU meter -->
                    <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="MASTER" Foreground="#333" FontSize="8" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Border Width="14" Height="20" Background="#111" CornerRadius="2" Margin="0,0,2,0">
                                <Border Name="VuL" Width="14" Background="#00E5FF" CornerRadius="2" Height="0" VerticalAlignment="Bottom"/>
                            </Border>
                            <Border Width="14" Height="20" Background="#111" CornerRadius="2">
                                <Border Name="VuR" Width="14" Background="#00E5FF" CornerRadius="2" Height="0" VerticalAlignment="Bottom"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Vol master -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="VOL" Foreground="#333" FontSize="8" HorizontalAlignment="Center"/>
                        <Slider Name="SldMaster" Minimum="0" Maximum="1.5" Value="1"
                                Width="80" Margin="0,4,0,0" ValueChanged="SldMaster_Changed"/>
                    </StackPanel>

                    <!-- Botón agregar pista -->
                    <Button Content="+ Pista" Click="BtnAddTrack_Click" Height="32" Padding="10,0"
                            Background="#141414" Foreground="#00E5FF" BorderBrush="#00E5FF"
                            BorderThickness="1" FontSize="11" FontWeight="Bold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Exportar -->
                    <Button Content="↓ WAV" Click="BtnExport_Click" Height="32" Padding="8,0"
                            Background="#141414" Foreground="#FFD700" BorderBrush="#FFD700"
                            BorderThickness="1" FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="6,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Guardar -->
                    <Button Content="💾" Click="BtnSave_Click" Height="32" Width="32" Margin="6,0,0,0"
                            Background="#141414" Foreground="#FFD700" BorderBrush="#FFD700"
                            BorderThickness="1" FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ ZONA PRINCIPAL ════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>   <!-- Chat Draw.ia -->
                <ColumnDefinition Width="*"/>     <!-- Arrangement -->
            </Grid.ColumnDefinitions>

            <!-- Chat Draw.ia -->
            <Border Grid.Column="0" Background="#0D0D0D" BorderBrush="#141414" BorderThickness="0,0,1,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="✦ Draw.ia" Foreground="#FF007F" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="Asistente de audio inteligente" Foreground="#333" FontSize="10" Margin="0,2,0,0"/>
                        <Border Height="1" Background="#141414" Margin="0,8,0,0"/>
                    </StackPanel>

                    <ScrollViewer Name="ChatScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Name="ChatPanel">
                            <Border Background="#111" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#555">
                                    Draw.ia listo. Puedo ajustar efectos, sugerir mezclas y controlar el rack.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#111" CornerRadius="4" BorderBrush="#1E1E1E" BorderThickness="1">
                            <TextBox Name="TxtPrompt" Background="Transparent" Foreground="#AAA"
                                     BorderThickness="0" Padding="8,6" FontSize="11"
                                     CaretBrush="#FF007F" KeyDown="TxtPrompt_KeyDown"
                                     TextWrapping="Wrap" MaxLines="2"/>
                        </Border>
                        <Button Name="BtnSend" Grid.Column="1" Margin="4,0,0,0" Height="30" Width="28"
                                Background="#FF007F" BorderThickness="0" Cursor="Hand"
                                Click="BtnSend_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <TextBlock Text="▶" Foreground="White" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Arrangement -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>  <!-- Toolbar de edición -->
                    <RowDefinition Height="24"/>  <!-- Regla -->
                    <RowDefinition Height="*"/>   <!-- Pistas -->
                </Grid.RowDefinitions>

                <!-- Toolbar de edición -->
                <Border Grid.Row="0" Background="#0C0C0C" BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="HERRAMIENTAS:" Foreground="#222" FontSize="8"
                                   FontFamily="Courier New" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Name="BtnToolSelect" Content="▶  SELECCIÓN" Height="20" Padding="8,0"
                                Click="BtnToolSelect_Click" Cursor="Hand" Margin="0,0,4,0"
                                Background="#1A0808" Foreground="#FF007F"
                                BorderBrush="#FF007F" BorderThickness="1" FontSize="9">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Name="BtnToolCut" Content="✂  CORTAR" Height="20" Padding="8,0"
                                Click="BtnToolCut_Click" Cursor="Hand" Margin="0,0,16,0"
                                Background="#141414" Foreground="#555"
                                BorderBrush="#222" BorderThickness="1" FontSize="9">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="HANDLES: arrastra los bordes para recortar  ·  arrastra el centro para mover  ·  triángulos para fade"
                                   Foreground="#1E1E1E" FontSize="8" FontFamily="Courier New"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Regla de tiempo — clickable para seek -->
                <Border Grid.Row="1" Background="#0D0D0D" BorderBrush="#141414" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ARRANGEMENT" Foreground="#2A2A2A"
                                   FontSize="9" FontFamily="Courier New" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0"/>
                        <Canvas Grid.Column="1" Name="RulerCanvas"
                                Cursor="Hand"
                                MouseLeftButtonDown="RulerCanvas_Click"/>
                    </Grid>
                </Border>

                <!-- Lista de pistas con playhead superpuesto -->
                <Border Grid.Row="2" BorderBrush="#141414" BorderThickness="0">
                    <ScrollViewer Name="TrackScroller"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  PanningMode="Both">
                        <Grid Name="TrackGrid">
                            <StackPanel Name="TrackPanel">
                                <!-- Área vacía cuando no hay pistas -->
                                <Border Name="EmptyState" Background="#0D0D0D" Margin="20"
                                        CornerRadius="10" BorderBrush="#141414" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40,40">
                                        <TextBlock Text="📂" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Sin pistas" Foreground="#2A2A2A" FontSize="14"
                                                   HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="Haz clic en + Pista para importar audio"
                                                   Foreground="#1E1E1E" FontSize="11"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Playhead dentro del scroll — se mueve con las pistas -->
                            <Canvas Name="PlayheadCanvas" IsHitTestVisible="False"
                                    HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                <!-- Línea vertical rosa -->
                                <Rectangle Name="PlayheadLine"
                                           Width="2" Fill="#FF007F"
                                           Height="3000"
                                           Canvas.Top="0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect Color="#FF007F" BlurRadius="5" ShadowDepth="0"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <!-- Triángulo en la cabeza -->
                                <Polygon Name="PlayheadHead"
                                         Points="0,0 12,0 6,9"
                                         Fill="#FF007F"/>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ EFFECTS RACK ══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="#141414" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12,0" Background="#0A0A0A">
                    <TextBlock Text="EFFECTS RACK  //  MASTER BUS" Foreground="#1E1E1E"
                               FontSize="9" FontFamily="Courier New" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Name="RackPanel" Margin="10,6,10,6"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
